  "tokenColors": [
    {
      "name": "Base foreground",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#F8F7FF"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6DFCE8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF2DAA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#39FF6B"
      }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFF75E"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#00E5FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#B78CFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Parameters and local variables",
      "scope": [
        "variable.parameter",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#FF8CFF"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#7CFFC4"
      }
    },
    {
      "name": "Operators and punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#E9DEFF"
      }
    },
    {
      "name": "Decorators / special",
      "scope": [
        "meta.decorator",
        "entity.name.tag",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FFB86B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#FF3D67"
      }
    }
  ],
  "semanticTokenColors": {
    "variable.readonly": {
      "foreground": "#F8F7FF"
    },
    "variable.defaultLibrary": {
      "foreground": "#F8F7FF"
    },
    "property": {
      "foreground": "#7CFFC4"
    },
    "parameter": {
      "foreground": "#FF8CFF"
    },
    "function": {
      "foreground": "#00E5FF",
      "bold": true
    },
    "method": {
      "foreground": "#00E5FF",
      "bold": true
    },
    "class": {
      "foreground": "#B78CFF",
      "bold": true
    },
    "interface": {
      "foreground": "#B78CFF",
      "bold": true
    },
    "type": {
      "foreground": "#B78CFF",
      "bold": true
    },
    "enum": {
      "foreground": "#FFF75E"
    },
    "enumMember": {
      "foreground": "#FFF75E"
    },
    "namespace": {
      "foreground": "#C77DFF"
    },
    "keyword": {
      "foreground": "#FF2DAA",
      "bold": true
    },
    "stringLiteral": {
      "foreground": "#39FF6B"
    },
    "numberLiteral": {
      "foreground": "#FFF75E"
    },
    "regexp": {
      "foreground": "#FFB86B"
    },
    "decorator": {
      "foreground": "#FFB86B",
      "bold": true
    }
  }
}
